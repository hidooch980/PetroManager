// ==========================================
// PetroManager-AI — Prisma Schema (Stage 1 & 2)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------
// Enums
// ------------------------------------------

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum FuelType {
  PETROL_REGULAR
  PETROL_SUPER
  DIESEL
  CNG
  OTHER
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  SALARY_ADVANCE
  SUPPLIES
  OTHER
}

// ------------------------------------------
// Core / Auth
// ------------------------------------------

model User {
  id           String    @id @default(uuid())
  fullName     String
  username     String    @unique
  passwordHash String
  role         UserRole  @default(OPERATOR)
  isActive     Boolean   @default(true)

  employee     Employee?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Station {
  id           String   @id @default(uuid())
  name         String
  address      String?
  phone        String?
  licenseNo    String?

  tanks        FuelTank[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("stations")
}

// ------------------------------------------
// Employees & Shifts
// ------------------------------------------

model Employee {
  id           String    @id @default(uuid())
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])

  fullName     String
  nationalId   String?   @unique
  phone        String?
  position     String?
  hireDate     DateTime?
  baseSalary   Decimal?  @db.Decimal(12, 2)
  isActive     Boolean   @default(true)

  shifts       Shift[]
  payrolls     Payroll[]
  attendances  Attendance[]
  insuranceRecords InsuranceRecord[]
  taxRecords   TaxRecord[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("employees")
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])

  checkIn     DateTime
  checkOut    DateTime?
  note        String?

  createdAt   DateTime  @default(now())

  @@map("attendances")
}

model Shift {
  id            String      @id @default(uuid())
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])

  startedAt     DateTime
  endedAt       DateTime?
  status        ShiftStatus @default(OPEN)

  openingCash   Decimal     @db.Decimal(12, 2) @default(0)
  closingCash   Decimal?    @db.Decimal(12, 2)
  cashDifference Decimal?   @db.Decimal(12, 2)

  sales         Sale[]
  expenses      Expense[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("shifts")
}

// ------------------------------------------
// Fuel: Tanks, Deliveries, Inventory
// ------------------------------------------

model FuelTank {
  id           String     @id @default(uuid())
  stationId    String
  station      Station    @relation(fields: [stationId], references: [id])

  fuelType     FuelType
  capacity     Decimal    @db.Decimal(12, 2)
  currentLevel Decimal    @db.Decimal(12, 2) @default(0)

  deliveries   FuelDelivery[]
  sales        Sale[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("fuel_tanks")
}

model FuelDelivery {
  id          String    @id @default(uuid())
  tankId      String
  tank        FuelTank  @relation(fields: [tankId], references: [id])

  supplierName String?
  quantity     Decimal  @db.Decimal(12, 2)
  unitCost     Decimal  @db.Decimal(12, 2)
  totalCost    Decimal  @db.Decimal(14, 2)
  deliveredAt  DateTime @default(now())
  invoiceNo    String?

  createdAt    DateTime @default(now())

  @@map("fuel_deliveries")
}

// ------------------------------------------
// Sales
// ------------------------------------------

model Sale {
  id          String    @id @default(uuid())
  shiftId     String
  shift       Shift     @relation(fields: [shiftId], references: [id])

  tankId      String?
  tank        FuelTank? @relation(fields: [tankId], references: [id])

  fuelType    FuelType?
  quantity    Decimal?  @db.Decimal(12, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalAmount Decimal   @db.Decimal(14, 2)

  description String?   // برای فروش سایر فرآورده‌ها (روغن، لاستیک، ...)
  paymentMethod String? // نقدی، کارت، اعتباری

  soldAt      DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@map("sales")
}

// ------------------------------------------
// Expenses
// ------------------------------------------

model Expense {
  id          String          @id @default(uuid())
  shiftId     String?
  shift       Shift?          @relation(fields: [shiftId], references: [id])

  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  paidAt      DateTime        @default(now())

  createdAt   DateTime        @default(now())

  @@map("expenses")
}

// ------------------------------------------
// Payroll (Stage 4 — included early for FK stability)
// ------------------------------------------

model Payroll {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  periodMonth Int
  periodYear  Int
  baseAmount  Decimal  @db.Decimal(12, 2)
  bonuses     Decimal  @db.Decimal(12, 2) @default(0)
  deductions  Decimal  @db.Decimal(12, 2) @default(0)
  netAmount   Decimal  @db.Decimal(12, 2)

  paidAt      DateTime?
  createdAt   DateTime @default(now())

  @@unique([employeeId, periodMonth, periodYear])
  @@map("payrolls")
}

// ------------------------------------------
// Insurance (Stage 4)
// ------------------------------------------

model InsuranceRecord {
  id             String   @id @default(uuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])

  periodMonth    Int
  periodYear     Int
  baseAmount     Decimal  @db.Decimal(12, 2)
  employeeShare  Decimal  @db.Decimal(12, 2)
  employerShare  Decimal  @db.Decimal(12, 2)
  totalAmount    Decimal  @db.Decimal(12, 2)

  createdAt      DateTime @default(now())

  @@unique([employeeId, periodMonth, periodYear])
  @@map("insurance_records")
}

// ------------------------------------------
// Tax (Stage 4)
// ------------------------------------------

model TaxRecord {
  id             String   @id @default(uuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])

  periodMonth    Int
  periodYear     Int
  taxableAmount  Decimal  @db.Decimal(12, 2)
  taxAmount      Decimal  @db.Decimal(12, 2)

  createdAt      DateTime @default(now())

  @@unique([employeeId, periodMonth, periodYear])
  @@map("tax_records")
}
